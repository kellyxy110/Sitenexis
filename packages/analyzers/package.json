{
  "name": "@sitenexis/analyzers",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fixes": {
      "types": "./dist/fixes/index.d.ts",
      "default": "./dist/fixes/index.js"
    },
    "./adnexis": {
      "types": "./dist/adnexis/index.d.ts",
      "default": "./dist/adnexis/index.js"
    },
    "./ai-telemetry": {
      "types": "./dist/ai/telemetry.d.ts",
      "default": "./dist/ai/telemetry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sitenexis/adapters": "workspace:*",
    "@sitenexis/shared": "workspace:*",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
