generator client {
  provider      = "prisma-client-js"
  output        = "./generated"
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  free
  starter
  pro
  agency
  enterprise
}

enum AuditStatus {
  queued
  running
  complete
  failed
}

enum IssueSeverity {
  critical
  warning
  info
}

// ─── v1 models ───────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  avatarUrl        String?   @map("avatar_url")
  plan             Plan      @default(free)
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  archivedAt       DateTime? @map("archived_at")

  creditBalance      Int      @default(10) @map("credit_balance")
  isUnlimited        Boolean  @default(false) @map("is_unlimited")

  audits             Audit[]
  apiKeys            ApiKey[]
  usageLogs          UsageLog[]
  creditTransactions CreditTransaction[]
  ownedTeamMembers   TeamMember[]        @relation("TeamOwner")
  memberOfTeams      TeamMember[]        @relation("TeamMember")
  sentInvites        TeamInvite[]        @relation("InviteOwner")
  scheduledReports   ScheduledReport[]
  ads                Ad[]                @relation("UserAds")
  adGenerations      AdGeneration[]      @relation("UserAdGenerations")

  @@map("users")
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String   // 'credit' | 'debit'
  amount      Int
  actionType  String   @map("action_type")
  description String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user  User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("credit_transactions")
}

model Audit {
  id              String      @id @default(cuid())
  userId          String      @map("user_id")
  domain          String
  status          AuditStatus @default(queued)
  startedAt       DateTime?   @map("started_at")
  completedAt     DateTime?   @map("completed_at")
  errorMessage    String?     @map("error_message")
  pageCount       Int?        @map("page_count")
  crawlDurationMs Int?        @map("crawl_duration_ms")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  archivedAt      DateTime?   @map("archived_at")

  user                     User                      @relation(fields: [userId], references: [id])
  pages                    Page[]
  issues                   Issue[]
  scores                   AuditScore?
  report                   Report?
  usageLogs                UsageLog[]
  aiVisibilityScores       AIVisibilityScore?
  perceptionGraphSnapshot  PerceptionGraphSnapshot?
  retrievalSimulations     RetrievalSimulation[]
  machineTrustScore        MachineTrustScore?
  temporalAuthorityRecord  TemporalAuthorityRecord?
  recommendationSurfaceMap RecommendationSurfaceMap?
  syntheticEntityFlags     SyntheticEntityFlag[]
  siiScore                 SIIScore?
  sseScore                 SseScore?
  informationGainResult    InformationGainResult?
  scoutAnalysis            ScoutAnalysis?
  // Graph Core v1 (append-only, derived from DOM extraction)
  factNodes                FactNode[]
  factEdges                FactEdge[]
  perceptionNodes          PerceptionNode[]
  perceptionEdges          PerceptionEdge[]

  // v4 — Competitive Intelligence Layer
  v4IntelligenceScore      V4IntelligenceScore?
  competitivePosition      CompetitivePosition?
  displacementRecord       DisplacementRecord?
  uncertaintyDecomposition UncertaintyDecomposition?
  trajectoryScenarios      TrajectoryScenario[]
  queryClusters            QueryCluster[]
  competitiveSetMembers    CompetitiveSetMember[]
  scoreDeltasFrom          ScoreDelta[] @relation("ScoreDeltaFromAudit")
  scoreDeltasTo            ScoreDelta[] @relation("ScoreDeltaToAudit")

  @@index([userId])
  @@index([domain])
  @@index([status])
  @@map("audits")
}

model Page {
  id               String    @id @default(cuid())
  auditId          String    @map("audit_id")
  url              String
  statusCode       Int       @map("status_code")
  title            String?
  metaDescription  String?   @map("meta_description")
  h1               String?
  canonicalUrl     String?   @map("canonical_url")
  wordCount        Int       @default(0) @map("word_count")
  isIndexable      Boolean   @default(true) @map("is_indexable")
  robotsDirective  String?   @map("robots_directive")
  internalLinks    Int       @default(0) @map("internal_links")
  externalLinks    Int       @default(0) @map("external_links")
  internalLinksOut Json      @default("[]") @map("internal_links_out")
  pageRank         Float     @default(0) @map("page_rank")
  seoScore         Float?    @map("seo_score")
  seoIssues        Json      @default("[]") @map("seo_issues")
  aiScore          Float?    @map("ai_score")
  aiStatus         String    @default("pending") @map("ai_status")
  schemaData       Json      @default("[]") @map("schema_data")
  bodyText         String?   @map("body_text")
  crawledAt        DateTime  @map("crawled_at")
  archivedAt       DateTime? @map("archived_at")

  audit  Audit        @relation(fields: [auditId], references: [id])
  issues Issue[]
  chunks PageChunk[]

  @@index([auditId])
  @@map("pages")
}

model Issue {
  id             String        @id @default(cuid())
  auditId        String        @map("audit_id")
  pageId         String?       @map("page_id")
  pageUrl        String?       @map("page_url")
  module         String
  type           String
  severity       IssueSeverity
  message        String
  recommendation String
  problem        String?
  solution       String?
  fixCode        String?       @map("fix_code")
  fixLanguage    String?       @map("fix_language")
  createdAt      DateTime      @default(now()) @map("created_at")

  audit  Audit  @relation(fields: [auditId], references: [id])
  page   Page?  @relation(fields: [pageId], references: [id])

  @@index([auditId])
  @@index([severity])
  @@map("issues")
}

model AuditScore {
  id               String   @id @default(cuid())
  auditId          String   @unique @map("audit_id")
  overall          Float
  seoScore         Float    @map("seo_score")
  aiScore          Float    @map("ai_score")
  schemaScore      Float    @map("schema_score")
  linkGraphScore   Float    @map("link_graph_score")
  performanceScore Float    @map("performance_score")
  breakdown        Json
  createdAt        DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("audit_scores")
}

model Report {
  id          String    @id @default(cuid())
  auditId     String    @unique @map("audit_id")
  pdfUrl      String    @map("pdf_url")
  generatedAt DateTime  @default(now()) @map("generated_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("reports")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  keyHash    String    @unique @map("key_hash")
  label      String
  lastUsed   DateTime? @map("last_used")
  createdAt  DateTime  @default(now()) @map("created_at")
  archivedAt DateTime? @map("archived_at")

  user  User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("api_keys")
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  auditId   String?  @map("audit_id")
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id])
  audit  Audit? @relation(fields: [auditId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("usage_logs")
}

// ─── v2 models ───────────────────────────────────────────────────────────────

model PageChunk {
  id        String   @id @default(cuid())
  pageId    String   @map("page_id")
  auditId   String   @map("audit_id")
  index     Int
  text      String
  tokenCount Int     @map("token_count")
  embedding Float[]
  createdAt DateTime @default(now()) @map("created_at")

  page  Page @relation(fields: [pageId], references: [id])

  @@index([pageId])
  @@index([auditId])
  @@map("page_chunks")
}

model Entity {
  id                   String   @id @default(cuid())
  auditId              String   @map("audit_id")
  name                 String
  normalizedName       String   @map("normalized_name")
  type                 String
  description          String?
  sameAsUrls           String[] @map("same_as_urls")
  mentionCount         Int      @default(0) @map("mention_count")
  consistencyScore     Float    @default(0) @map("consistency_score")
  disambiguationScore  Float    @default(0) @map("disambiguation_score")
  createdAt            DateTime @default(now()) @map("created_at")

  relationships EntityRelationship[] @relation("sourceEntity")

  @@index([auditId])
  @@index([normalizedName])
  @@map("entities")
}

model EntityRelationship {
  id               String   @id @default(cuid())
  auditId          String   @map("audit_id")
  sourceEntityId   String   @map("source_entity_id")
  targetEntityId   String   @map("target_entity_id")
  relationshipType String   @map("relationship_type")
  strength         Float    @default(0.5)
  evidencedByUrls  String[] @map("evidenced_by_urls")
  createdAt        DateTime @default(now()) @map("created_at")

  sourceEntity  Entity @relation("sourceEntity", fields: [sourceEntityId], references: [id])

  @@index([auditId])
  @@index([sourceEntityId])
  @@map("entity_relationships")
}

model AIVisibilityScore {
  id                         String   @id @default(cuid())
  auditId                    String   @unique @map("audit_id")
  aiVisibilityScore          Float    @map("ai_visibility_score")
  machineReadabilityScore    Float    @map("machine_readability_score")
  entityConfidenceScore      Float    @map("entity_confidence_score")
  retrievalReadinessScore    Float    @map("retrieval_readiness_score")
  citationProbabilityScore   Float    @map("citation_probability_score")
  semanticTrustScore         Float    @map("semantic_trust_score")
  recommendationConfidence   Float    @map("recommendation_confidence")
  providerScores             Json     @map("provider_scores")
  breakdown                  Json
  createdAt                  DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("ai_visibility_scores")
}

model PerceptionGraphSnapshot {
  id                       String   @id @default(cuid())
  auditId                  String   @unique @map("audit_id")
  nodesJson                Json     @map("nodes_json")
  edgesJson                Json     @map("edges_json")
  perceptionConfidenceScore Float   @default(0) @map("perception_confidence_score")
  createdAt                DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("perception_graph_snapshots")
}

// ─── v3 models ───────────────────────────────────────────────────────────────

model RetrievalSimulation {
  id                         String   @id @default(cuid())
  auditId                    String   @map("audit_id")
  pageUrl                    String   @map("page_url")
  simulated                  Boolean  @default(true)
  simulationErrorReason      String?  @map("simulation_error_reason")
  retrievalQualityScore      Float?   @map("retrieval_quality_score")
  chunkStabilityIndex        Float?   @map("chunk_stability_index")
  answerFormationProbability Float?   @map("answer_formation_probability")
  summarisationLossScore     Float?   @map("summarisation_loss_score")
  citationEligibilityScore   Float?   @map("citation_eligibility_score")
  fragileClaimsCount         Int      @default(0) @map("fragile_claims_count")
  retrievalFailures          Json     @default("[]") @map("retrieval_failures")
  truncationZoneWarnings     String[] @map("truncation_zone_warnings")
  createdAt                  DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@map("retrieval_simulations")
}

model MachineTrustScore {
  id                          String   @id @default(cuid())
  auditId                     String   @unique @map("audit_id")
  overall                     Float
  entityCredibilityScore      Float    @map("entity_credibility_score")
  schemaTrustAlignmentScore   Float    @map("schema_trust_alignment_score")
  externalValidationScore     Float    @map("external_validation_score")
  contradictionAbsenceScore   Float?   @map("contradiction_absence_score")
  trustDegradationResistance  Float    @map("trust_degradation_resistance")
  crossSourceValidationIndex  Float    @map("cross_source_validation_index")
  trustIssues                 Json     @default("[]") @map("trust_issues")
  degradationSignals          Json     @default("[]") @map("degradation_signals")
  createdAt                   DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("machine_trust_scores")
}

model TemporalAuthorityRecord {
  id                              String   @id @default(cuid())
  auditId                         String   @unique @map("audit_id")
  isBaseline                      Boolean  @default(false) @map("is_baseline")
  authorityVelocityScore          Float?   @map("authority_velocity_score")
  trustStabilityIndex             Float    @default(1.0) @map("trust_stability_index")
  contentFreshnessImpactFactor    Float    @default(1.0) @map("content_freshness_impact_factor")
  semanticDriftIndex              Float    @default(0) @map("semantic_drift_index")
  updateFrequencyClassification   String   @map("update_frequency_classification")
  stalePagesAtRisk                String[] @map("stale_pages_at_risk")
  driftedPages                    Json     @default("[]") @map("drifted_pages")
  temporalIssues                  Json     @default("[]") @map("temporal_issues")
  createdAt                       DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("temporal_authority_records")
}

model RecommendationSurfaceMap {
  id                        String   @id @default(cuid())
  auditId                   String   @unique @map("audit_id")
  overallSurfaceScore       Float    @map("overall_surface_score")
  aiOverviewsProbability    Float    @map("ai_overviews_probability")
  aiOverviewsStatus         String   @map("ai_overviews_status")
  chatProbability           Float    @map("chat_probability")
  chatStatus                String   @map("chat_status")
  voiceProbability          Float    @map("voice_probability")
  voiceStatus               String   @map("voice_status")
  agentProbability          Float    @map("agent_probability")
  agentStatus               String   @map("agent_status")
  coverageGaps              Json     @default("[]") @map("coverage_gaps")
  missingChannels           String[] @map("missing_channels")
  createdAt                 DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@map("recommendation_surface_maps")
}

model SyntheticEntityFlag {
  id                         String   @id @default(cuid())
  auditId                    String   @map("audit_id")
  syntheticRiskScore         Float    @map("synthetic_risk_score")
  entityAuthenticityConfidence Float  @map("entity_authenticity_confidence")
  networkIntegrityScore      Float    @map("network_integrity_score")
  detectedPatterns           Json     @default("[]") @map("detected_patterns")
  flaggedEntities            Json     @default("[]") @map("flagged_entities")
  recommendations            String[] @map("recommendations")
  createdAt                  DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@map("synthetic_entity_flags")
}

// ─── Self-Audit / Continuous Monitoring ──────────────────────────────────────
// These tables store aggregated time-series data for the continuous self-audit
// of https://sitenexis.com. Every deployment and scheduled run writes here.

model SelfAuditRun {
  id            String   @id @default(cuid())
  domain        String   @default("sitenexis.com")
  triggeredBy   String   @map("triggered_by")    // 'deploy' | 'cron' | 'manual'
  status        String   @default("running")

  // Linked regular audit (the underlying infrastructure-agent run)
  auditId       String?  @unique @map("audit_id")

  // SiteNexis Health Score + 7 dimension scores (all 0–100)
  healthScore           Float? @map("health_score")
  technicalSeoScore     Float? @map("technical_seo_score")
  aiVisibilityScore     Float? @map("ai_visibility_score")
  entityCoverageScore   Float? @map("entity_coverage_score")
  citationReadinessScore Float? @map("citation_readiness_score")
  knowledgeGraphScore   Float? @map("knowledge_graph_score")
  trustSignalsScore     Float? @map("trust_signals_score")
  performanceScore      Float? @map("performance_score")
  geoScore              Float? @map("geo_score")

  // Aggregated breakdown + recommendations JSON
  breakdown       Json? @default("{}")
  recommendations Json? @default("[]")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  errorMessage String?  @map("error_message")

  crawlRun          CrawlRun?
  visibilityRun     VisibilityRun?
  entityRun         EntityRun?
  knowledgeGraphRun KnowledgeGraphRun?

  @@index([domain, startedAt])
  @@index([status])
  @@map("audit_runs")
}

model CrawlRun {
  id             String   @id @default(cuid())
  selfAuditRunId String   @unique @map("self_audit_run_id")
  domain         String

  pagesFound      Int   @default(0) @map("pages_found")
  pagesCrawled    Int   @default(0) @map("pages_crawled")
  pagesIndexable  Int   @default(0) @map("pages_indexable")
  crawlDurationMs Int   @default(0) @map("crawl_duration_ms")
  brokenLinksCount Int  @default(0) @map("broken_links_count")
  redirectChainCount Int @default(0) @map("redirect_chain_count")
  missingSitemapPages Int @default(0) @map("missing_sitemap_pages")
  crawlHealthScore Float @map("crawl_health_score")
  topIssues       Json  @default("[]") @map("top_issues")
  crawledAt       DateTime @default(now()) @map("crawled_at")

  selfAuditRun SelfAuditRun @relation(fields: [selfAuditRunId], references: [id])

  @@index([domain, crawledAt])
  @@map("crawl_runs")
}

model VisibilityRun {
  id             String   @id @default(cuid())
  selfAuditRunId String   @unique @map("self_audit_run_id")
  domain         String

  aiVisibilityScore        Float @map("ai_visibility_score")
  machineReadabilityScore  Float @map("machine_readability_score")
  retrievalReadinessScore  Float @map("retrieval_readiness_score")
  citationProbability      Float @map("citation_probability")
  semanticTrustScore       Float @map("semantic_trust_score")
  recommendationConfidence Float @map("recommendation_confidence")
  retrievalQualityScore    Float @default(0) @map("retrieval_quality_score")
  surfaceCoverageScore     Float @default(0) @map("surface_coverage_score")
  providerBreakdown        Json  @default("{}") @map("provider_breakdown")
  scannedAt                DateTime @default(now()) @map("scanned_at")

  selfAuditRun SelfAuditRun @relation(fields: [selfAuditRunId], references: [id])

  @@index([domain, scannedAt])
  @@map("visibility_runs")
}

model EntityRun {
  id             String   @id @default(cuid())
  selfAuditRunId String   @unique @map("self_audit_run_id")
  domain         String

  entitiesDetected      Int    @default(0) @map("entities_detected")
  primaryEntityName     String? @map("primary_entity_name")
  entityConfidenceScore Float  @map("entity_confidence_score")
  entityConsistencyScore Float @map("entity_consistency_score")
  entityCoverageScore   Float  @map("entity_coverage_score")
  disambiguationScore   Float  @map("disambiguation_score")
  sameAsLinksCount      Int    @default(0) @map("same_as_links_count")
  authenticityScore     Float  @default(100) @map("authenticity_score")
  topEntities           Json   @default("[]") @map("top_entities")
  extractedAt           DateTime @default(now()) @map("extracted_at")

  selfAuditRun SelfAuditRun @relation(fields: [selfAuditRunId], references: [id])

  @@index([domain, extractedAt])
  @@map("entity_runs")
}

model KnowledgeGraphRun {
  id             String   @id @default(cuid())
  selfAuditRunId String   @unique @map("self_audit_run_id")
  domain         String

  nodeCount          Int    @default(0) @map("node_count")
  edgeCount          Int    @default(0) @map("edge_count")
  topicClusters      Int    @default(0) @map("topic_clusters")
  avgNodeConfidence  Float  @default(0) @map("avg_node_confidence")
  graphStrengthScore Float  @map("graph_strength_score")
  topNodes           Json   @default("[]") @map("top_nodes")
  generatedAt        DateTime @default(now()) @map("generated_at")

  selfAuditRun SelfAuditRun @relation(fields: [selfAuditRunId], references: [id])

  @@index([domain, generatedAt])
  @@map("knowledge_graph_runs")
}

// ─── SiteNexis Intelligence Index ────────────────────────────────────────────

model SIIScore {
  id      String @id @default(cuid())
  auditId String @unique @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  siiScore   Float @map("sii_score")
  confidence Float

  /// Raw dimension scores (0–100, nullable when input was unavailable)
  breakdown             Json
  /// Weighted contributions (score × weight for each dimension)
  weightedContributions Json @map("weighted_contributions")
  /// Machine-interpretable observations
  insights              Json
  /// Dimension or data gaps preventing accurate scoring
  criticalGaps          Json @map("critical_gaps")
  /// Prioritised recommendations sorted by expected SII gain
  recommendations       Json

  createdAt DateTime @default(now()) @map("created_at")

  @@map("sii_scores")
}

// ─── SSE — SiteNexis Scoring Engine ──────────────────────────────────────────

model SseScore {
  id      String @id @default(cuid())
  auditId String @unique @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  // Topical Authority (TA = Depth×0.4 + Breadth×0.3 + Interlinking×0.2 + Freshness×0.1)
  topicalAuthorityScore Float @map("topical_authority_score")
  taDepth               Float @map("ta_depth")
  taBreadth             Float @map("ta_breadth")
  taInterlinking        Float @map("ta_interlinking")
  taFreshness           Float @map("ta_freshness")

  // Semantic Density Score (SDS = (entities+facts+relationships)/words×1000, normalised)
  semanticDensityScore  Float @map("semantic_density_score")
  sdsRawDensity         Float @map("sds_raw_density")
  sdsEntityCount        Int   @map("sds_entity_count")
  sdsFactCount          Int   @map("sds_fact_count")
  sdsRelationshipCount  Int   @map("sds_relationship_count")
  sdsTotalWords         Int   @map("sds_total_words")

  // AI Crawlability Index (ACI = Robots×0.30 + Sitemap×0.25 + Renderability×0.20 + Indexability×0.25)
  aiCrawlabilityScore   Float @map("ai_crawlability_score")
  aciRobots             Float @map("aci_robots")
  aciSitemap            Float @map("aci_sitemap")
  aciRenderability      Float @map("aci_renderability")
  aciIndexability       Float @map("aci_indexability")

  // GEO Score (GEO = CP×0.25 + RR×0.20 + ST×0.20 + TA×0.15 + MR×0.10 + EC×0.10)
  geoScore              Float @map("geo_score")

  // SNS Master Score (SNS = AVS×0.15 + GEO×0.15 + … ten inputs weighted)
  snsMasterScore        Float  @map("sns_master_score")
  snsLabel              String @map("sns_label")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("sse_scores")
}

// ─── Team workspaces ─────────────────────────────────────────────────────────

model TeamMember {
  id       String   @id @default(cuid())
  ownerId  String   @map("owner_id")
  userId   String   @map("user_id")
  role     String   @default("viewer")
  joinedAt DateTime @default(now()) @map("joined_at")

  owner  User @relation("TeamOwner",  fields: [ownerId], references: [id])
  member User @relation("TeamMember", fields: [userId],  references: [id])

  @@unique([ownerId, userId])
  @@index([ownerId])
  @@map("team_members")
}

model TeamInvite {
  id        String    @id @default(cuid())
  ownerId   String    @map("owner_id")
  email     String
  role      String    @default("viewer")
  token     String    @unique @default(cuid())
  accepted  Boolean   @default(false)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  owner User @relation("InviteOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([email])
  @@map("team_invites")
}

// ─── Scheduled reports ───────────────────────────────────────────────────────

model ScheduledReport {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  domain     String?
  frequency  String    // 'daily' | 'weekly' | 'monthly'
  dayOfWeek  Int?      @map("day_of_week")
  hour       Int       @default(8)
  email      String
  enabled    Boolean   @default(true)
  lastSentAt DateTime? @map("last_sent_at")
  nextSendAt DateTime  @map("next_send_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([nextSendAt])
  @@map("scheduled_reports")
}

// ─── Information Gain Engine ─────────────────────────────────────────────────

model InformationGainResult {
  id              String   @id @default(cuid())
  auditId         String   @unique @map("audit_id")
  keyword         String
  targetUrl       String   @map("target_url")
  cohortSize      Int      @default(0) @map("cohort_size")
  overallScore    Int      @default(0) @map("overall_score")
  confidence      Float    @default(0)
  state           String   @default("empty")
  cohortPagesJson Json     @default("[]") @map("cohort_pages_json")
  resultJson      Json     @map("result_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  audit Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@map("information_gain_results")
}

// ─── Graph Core v1 — Fact Graph (append-only, DOM-extracted truth) ───────────
//
// Implementation rules:
//   - Every row traces back to a crawl event via audit_id + created_at
//   - confidence = 1.0 for DOM-extracted facts; lower only for inferred schema entities
//   - Never delete rows — soft-delete via audit archival only
//   - Perception tables NEVER write back into fact tables (one-way derivation)

model FactNode {
  id         String   @id @default(cuid())
  auditId    String   @map("audit_id")
  /// page | schema_entity | external_domain
  nodeType   String   @map("node_type")
  /// URL for page/external_domain nodes; entity name for schema_entity
  label      String
  url        String?
  /// dom | schema | sitemap
  source     String   @default("dom")
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([nodeType])
  @@index([url])
  @@map("fact_nodes")
}

model FactEdge {
  id           String   @id @default(cuid())
  auditId      String   @map("audit_id")
  fromUrl      String   @map("from_url")
  toUrl        String   @map("to_url")
  /// INTERNAL_LINK | EXTERNAL_LINK | SCHEMA_REL
  relationship String
  anchorText   String?  @map("anchor_text")
  /// nav | body | footer | sidebar | other
  position     String?
  isNoFollow   Boolean  @default(false) @map("is_no_follow")
  confidence   Float    @default(1.0)
  createdAt    DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([fromUrl])
  @@index([toUrl])
  @@map("fact_edges")
}

// ─── Graph Core v1 — Perception Graph (append-only, AI-inferred only) ─────────
//
// Rows here MUST be derived from the Fact Graph — never fabricated independently.
// confidence < 0.5 rows are stored but suppressed in UI rendering (PCE gate).

model PerceptionNode {
  id                     String   @id @default(cuid())
  auditId                String   @map("audit_id")
  /// Hash ID from the in-memory PerceptionGraphSnapshot — used to join perception edges
  nodeRef                String   @map("node_ref")
  /// entity | topic | claim | page
  nodeType               String   @map("node_type")
  label                  String
  confidence             Float    @default(0)
  citationReadiness      Float    @default(0) @map("citation_readiness")
  disambiguationStrength Float    @default(0) @map("disambiguation_strength")
  derivedFrom            String   @default("fact_graph") @map("derived_from")
  createdAt              DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([nodeType])
  @@map("perception_nodes")
}

model PerceptionEdge {
  id               String   @id @default(cuid())
  auditId          String   @map("audit_id")
  /// Hash ID of the source PerceptionNode (matches nodeRef)
  sourceRef        String   @map("source_ref")
  /// Hash ID of the target PerceptionNode (matches nodeRef)
  targetRef        String   @map("target_ref")
  relationshipType String   @map("relationship_type")
  strength         Float    @default(0)
  derivedFrom      String   @default("ai_inference") @map("derived_from")
  createdAt        DateTime @default(now()) @map("created_at")

  audit  Audit @relation(fields: [auditId], references: [id])

  @@index([auditId])
  @@index([sourceRef])
  @@map("perception_edges")
}

// ─── AdNexis models ──────────────────────────────────────────────────────────

enum AdPlatform {
  meta
  tiktok
  youtube
  native
  other
}

enum AdMediaType {
  video
  image
  text
  carousel
}

enum HookType {
  curiosity
  shock
  authority
  story
  fear
  transformation
}

enum AdFunnelStage {
  TOFU
  MOFU
  BOFU
}

enum AdCtaType {
  scarcity
  soft
  urgency
  curiosity_cta
}

enum AdFatigueRisk {
  low
  medium
  high
}

model Ad {
  id                 String         @id @default(cuid())
  userId             String         @map("user_id")
  platform           AdPlatform     @default(other)
  mediaType          AdMediaType    @default(text) @map("media_type")
  sourceUrl          String?        @map("source_url")
  mediaUrl           String?        @map("media_url")
  transcript         String?        @db.Text
  title              String?
  description        String?        @db.Text
  hook               String?
  hookType           HookType?      @map("hook_type")
  emotions           String[]
  funnelStage        AdFunnelStage? @map("funnel_stage")
  ctaType            AdCtaType?     @map("cta_type")
  ctaText            String?        @map("cta_text")
  audience           String?
  niche              String?
  tags               String[]
  performanceScore   Int?           @map("performance_score")
  hookStrength       Int?           @map("hook_strength")
  emotionalIntensity Int?           @map("emotional_intensity")
  noveltyScore       Int?           @map("novelty_score")
  fatigueRisk        AdFatigueRisk? @map("fatigue_risk")
  conversionLikelihood String?      @map("conversion_likelihood")
  estimatedRunwayDays  Int?         @map("estimated_runway_days")
  analysisJson       Json?          @map("analysis_json")
  analysisStatus     String         @default("pending") @map("analysis_status")
  createdAt          DateTime       @default(now()) @map("created_at")
  analyzedAt         DateTime?      @map("analyzed_at")
  archivedAt         DateTime?      @map("archived_at")

  user        User           @relation("UserAds", fields: [userId], references: [id])
  generations AdGeneration[]

  @@index([userId])
  @@index([platform])
  @@index([hookType])
  @@index([funnelStage])
  @@map("ads")
}

model ScoutAnalysis {
  id         String   @id @default(cuid())
  auditId    String   @unique @map("audit_id")
  domain     String
  state      String   @default("empty")
  resultJson Json     @map("result_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  audit Audit @relation(fields: [auditId], references: [id])

  @@index([domain])
  @@map("scout_analyses")
}

model AdGeneration {
  id           String   @id @default(cuid())
  adId         String?  @map("ad_id")
  userId       String   @map("user_id")
  inputText    String   @map("input_text") @db.Text
  platforms    String[]
  tone         String   @default("balanced")
  localization String?
  count        Int      @default(3)
  variations   Json
  createdAt    DateTime @default(now()) @map("created_at")

  ad   Ad?  @relation(fields: [adId], references: [id])
  user User @relation("UserAdGenerations", fields: [userId], references: [id])

  @@index([userId])
  @@map("ad_generations")
}

// ─── v4 — Competitive Intelligence Layer ─────────────────────────────────────
//
// Design principles:
//   - V4IntelligenceScore is the diagnostic overlay (interpretability layer)
//   - CompetitivePosition + QueryCluster are the simulation outputs (primary truth)
//   - TrajectoryScenario stores all scenario × time combinations (queryable)
//   - DisplacementRecord holds mechanism decomposition with reversibility flags
//   - UncertaintyDecomposition makes uncertainty explicit and named (never hidden)
//   - ScoreDelta is the temporal intelligence layer — requires 2+ audits per domain
//   - CompetitiveSetMember tracks which domains are in the competitive allocation pool

model V4IntelligenceScore {
  id      String @id @default(cuid())
  auditId String @unique @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  // Nine diagnostic scores (0–100). Derived from simulation state, not computed independently.
  aiVisibilityIndex                 Float @map("ai_visibility_index")
  citationProbabilityScore          Float @map("citation_probability_score")
  semanticClarityScore              Float @map("semantic_clarity_score")
  entityAuthorityScore              Float @map("entity_authority_score")
  trustCredibilityScore             Float @map("trust_credibility_score")
  contentDepthScore                 Float @map("content_depth_score")
  competitiveDifferentiationScore   Float @map("competitive_differentiation_score")
  retrievalSurfaceOptimizationScore Float @map("retrieval_surface_optimization_score")
  marketPositionStrength            Float @map("market_position_strength")

  // Weighted composite of all nine
  compositeIntelligenceScore Float @map("composite_intelligence_score")

  // { "aiVisibilityIndex": "Low-Mid", "citationProbabilityScore": "Low", ... }
  scoreBands Json @default("{}") @map("score_bands")

  // Full sub-component breakdown for explainability
  breakdown Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("v4_intelligence_scores")
}

model CompetitivePosition {
  id      String @id @default(cuid())
  auditId String @unique @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  primaryCluster String @map("primary_cluster")

  // Citation share — core category queries (e.g. "AI visibility tool")
  citationShareCoreLower   Float @map("citation_share_core_lower")
  citationShareCoreCentral Float @map("citation_share_core_central")
  citationShareCoreUpper   Float @map("citation_share_core_upper")

  // Citation share — niche concept queries (e.g. "machine trust scoring")
  citationShareNicheLower   Float @map("citation_share_niche_lower")
  citationShareNicheCentral Float @map("citation_share_niche_central")
  citationShareNicheUpper   Float @map("citation_share_niche_upper")

  // Estimated rank band within the tool category
  categoryRankLower Int @map("category_rank_lower")
  categoryRankUpper Int @map("category_rank_upper")

  // Position percentile in primary cluster (0–100)
  percentileLower   Float @map("percentile_lower")
  percentileCentral Float @map("percentile_central")
  percentileUpper   Float @map("percentile_upper")

  interpretation    String @default("below-median") // below-median | at-median | above-median | top-quartile
  positionStatement String @map("position_statement") @db.Text

  simulationModelVersion String @default("v4.1") @map("simulation_model_version")

  // Always present — captures assumptions used in this simulation run
  modelAssumptions Json @default("{}") @map("model_assumptions")

  createdAt DateTime @default(now()) @map("created_at")

  queryClusters QueryCluster[]

  @@map("competitive_positions")
}

model QueryCluster {
  id                    String @id @default(cuid())
  auditId               String @map("audit_id")
  competitivePositionId String @map("competitive_position_id")

  audit               Audit               @relation(fields: [auditId], references: [id])
  competitivePosition CompetitivePosition @relation(fields: [competitivePositionId], references: [id])

  clusterId String @map("cluster_id") // kebab-case slug
  label     String

  // informational | commercial | comparative | navigational | research
  intentType String @map("intent_type")

  // sparse | moderate | dense | saturated
  estimatedDensity String @map("estimated_density")

  citationBudgetLower Int @map("citation_budget_lower")
  citationBudgetUpper Int @map("citation_budget_upper")

  // declining | flat | growing | accelerating | unknown
  marketGrowthRate String @map("market_growth_rate")

  zeroSumDegree Float @map("zero_sum_degree") // 0–1

  // P(domain cited | Q) as probability interval
  shareLower   Float @map("share_lower")
  shareCentral Float @map("share_central")
  shareUpper   Float @map("share_upper")

  // Competitive percentile in this cluster
  percentileLower   Float @map("percentile_lower")
  percentileCentral Float @map("percentile_central")
  percentileUpper   Float @map("percentile_upper")

  // low | medium | high | dominant
  exposureLevel String @default("low") @map("exposure_level")

  // declining | flat | rising
  exposureTrend String @default("flat") @map("exposure_trend")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([auditId])
  @@index([competitivePositionId])
  @@index([intentType])
  @@map("query_clusters")
}

model TrajectoryScenario {
  id      String @id @default(cuid())
  auditId String @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  // do-nothing | complete-this-week | complete-sprint | complete-roadmap
  scenarioName String @map("scenario_name")

  // conservative | baseline | aggressive
  competitorAssumption String @map("competitor_assumption")

  // 30 | 90 | 365
  timeHorizonDays Int @map("time_horizon_days")

  // Projected citation share under this scenario
  projectedShareLower   Float @map("projected_share_lower")
  projectedShareCentral Float @map("projected_share_central")
  projectedShareUpper   Float @map("projected_share_upper")

  // Projected percentile under this scenario
  projectedPercentileLower   Float @map("projected_percentile_lower")
  projectedPercentileCentral Float @map("projected_percentile_central")
  projectedPercentileUpper   Float @map("projected_percentile_upper")

  primaryDriver String @default("") @map("primary_driver")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([auditId])
  @@index([scenarioName, timeHorizonDays])
  @@map("trajectory_scenarios")
}

model DisplacementRecord {
  id      String @id @default(cuid())
  auditId String @unique @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  atRisk Boolean @default(false) @map("at_risk")

  // competitor-improvement | trust-decay | market-saturation | none
  dominantMechanism String @map("dominant_mechanism")

  // Percentage contribution from each mechanism — should sum to ~100
  competitorImprovementPct Float @default(0) @map("competitor_improvement_pct")
  trustDecayPct            Float @default(0) @map("trust_decay_pct")
  marketSaturationPct      Float @default(0) @map("market_saturation_pct")

  reversibleByOwnAction Boolean @default(true) @map("reversible_by_own_action")

  // low | moderate | high | critical
  urgencyLevel String @default("low") @map("urgency_level")

  statement String @db.Text

  // Array of DisplacementMechanismDetail objects
  mechanismsJson Json @default("[]") @map("mechanisms_json")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("displacement_records")
}

model UncertaintyDecomposition {
  id      String @id @default(cuid())
  auditId String @unique @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  overallIntervalLower Float @map("overall_interval_lower")
  overallIntervalUpper Float @map("overall_interval_upper")

  // narrow | moderate | wide
  intervalWidth  String @map("interval_width")
  dominantSource String @map("dominant_source")
  howToNarrow    String @map("how_to_narrow") @db.Text

  // Array of UncertaintySource objects with name, contributionPct, reducible, description
  sourcesJson        Json     @default("[]") @map("sources_json")
  reducibleSources   String[] @map("reducible_sources")
  irreducibleSources String[] @map("irreducible_sources")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("uncertainty_decompositions")
}

model ScoreDelta {
  id          String @id @default(cuid())
  domain      String
  fromAuditId String @map("from_audit_id")
  toAuditId   String @map("to_audit_id")

  fromAudit Audit @relation("ScoreDeltaFromAudit", fields: [fromAuditId], references: [id])
  toAudit   Audit @relation("ScoreDeltaToAudit",   fields: [toAuditId],   references: [id])

  // Per-dimension deltas — positive = improving
  deltaAiVisibilityIndex            Float @default(0) @map("delta_ai_visibility_index")
  deltaCitationProbability          Float @default(0) @map("delta_citation_probability")
  deltaSemanticClarity              Float @default(0) @map("delta_semantic_clarity")
  deltaEntityAuthority              Float @default(0) @map("delta_entity_authority")
  deltaTrustCredibility             Float @default(0) @map("delta_trust_credibility")
  deltaContentDepth                 Float @default(0) @map("delta_content_depth")
  deltaCompetitiveDifferentiation   Float @default(0) @map("delta_competitive_differentiation")
  deltaRetrievalSurfaceOptimization Float @default(0) @map("delta_retrieval_surface_optimization")
  deltaMarketPositionStrength       Float @default(0) @map("delta_market_position_strength")

  deltaCompositeScore Float @default(0) @map("delta_composite_score")

  // improving | stable | declining
  velocityDirection     String @default("stable") @map("velocity_direction")
  primaryVelocityDriver String @default("")        @map("primary_velocity_driver")

  // Full delta map for flexible queries
  allDeltasJson Json @default("{}") @map("all_deltas_json")

  computedAt DateTime @default(now()) @map("computed_at")

  @@unique([fromAuditId, toAuditId])
  @@index([domain, computedAt])
  @@index([toAuditId])
  @@map("score_deltas")
}

model CompetitiveSetMember {
  id      String @id @default(cuid())
  auditId String @map("audit_id")
  audit   Audit  @relation(fields: [auditId], references: [id])

  domain     String
  // category-benchmark | direct-audit | none
  dataSource String @default("category-benchmark") @map("data_source")

  // Which query clusters this competitor appears in
  clusterIds String[] @map("cluster_ids")

  // { clusterId: relativeStrength (0–1) }
  clusterStrengthJson Json @default("{}") @map("cluster_strength_json")

  // FK to competitor's own audit record, if available
  competitorAuditId String? @map("competitor_audit_id")

  addedAt DateTime @default(now()) @map("added_at")

  @@index([auditId])
  @@index([domain])
  @@map("competitive_set_members")
}
