# ── Database ──────────────────────────────────────────────────────────────────
# Supabase pooled connection via PgBouncer — used by Prisma at runtime.
# Port 6543. Append ?pgbouncer=true to enable connection pooling.
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres?pgbouncer=true"

# Supabase direct connection — bypasses PgBouncer.
# Port 5432. Used by Prisma for migrations only (prisma migrate dev/deploy).
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ── Supabase (server-side) ────────────────────────────────────────────────────
# Your Supabase project URL. Found in: Supabase dashboard → Settings → API.
SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase anon key — safe for browser use. Limited Row Level Security permissions.
# Found in: Supabase dashboard → Settings → API → Project API keys.
SUPABASE_ANON_KEY="eyJ..."

# Supabase service role key — bypasses RLS, full DB access.
# Server-side ONLY. Never expose to the browser or commit to source control.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Supabase (browser-safe copies) ───────────────────────────────────────────
# These must match SUPABASE_URL and SUPABASE_ANON_KEY exactly.
# The NEXT_PUBLIC_ prefix makes them available in browser bundles.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Anthropic Claude — primary AI engine for all scoring and extraction.
# Used by /packages/analyzers/src/ai/ — server-side only.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Groq — fast fallback for structured scoring. Always-available baseline.
# Get your key at: https://console.groq.com
GROQ_API_KEY="gsk_..."

# OpenAI — optional fallback if Anthropic API is unavailable.
# Leave empty to disable the fallback.
OPENAI_API_KEY="sk-proj-..."

# ── OpenRouter — Multi-Model AI Engine ───────────────────────────────────────
# OpenRouter routes SiteNexis and AdNexis calls to 6 specialised free-tier models.
# Get keys at: https://openrouter.ai → API Keys (one free key per account, or per model)
#
# OPENROUTER_API_KEY is the fallback used when a model-specific key is not set.
# For rate-limit isolation, set per-model keys and use separate OpenRouter accounts.
#
# Model routing:
#   HERMES  (Nous Hermes 3 405B)   — structured scoring, entity extraction, ad generation
#   DEEPSEEK (DeepSeek V4 Flash)   — whole-site contradiction detection, performance prediction (1M ctx)
#   GEMMA   (Google Gemma 4 31B)   — visual/multimodal page analysis, ad creative review
#   QWEN    (Qwen3-Next 80B MoE)   — RAG simulation, high-throughput tasks
#   KIMI    (Moonshot Kimi K2.6)   — code generation, schema/JSON-LD, landing page generation
#   LLAMA   (Meta Llama 3.3 70B)   — multilingual site analysis (8 languages)
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_HERMES_KEY="sk-or-..."
OPENROUTER_DEEPSEEK_KEY="sk-or-..."
OPENROUTER_GEMMA_KEY="sk-or-..."
OPENROUTER_QWEN_KEY="sk-or-..."
OPENROUTER_KIMI_KEY="sk-or-..."
OPENROUTER_LLAMA_KEY="sk-or-..."

# ── Bynara Router ────────────────────────────────────────────────────────────
# OpenAI-compatible inference router. Provides Mistral Large and other models
# as a fallback tier after OpenRouter models. Integrates into the model-router
# fallback chain automatically when BYNARA_API_KEY is set.
# Get your key at: https://router.bynara.id
# Default endpoint: https://router.bynara.id/v1 (override with BYNARA_BASE_URL)
BYNARA_API_KEY=""
BYNARA_BASE_URL="https://router.bynara.id/v1"

# ── Serper (SERP API) ────────────────────────────────────────────────────────
# Real-time SERP data for the Information Gain Engine — entity gaps, question
# gaps, evidence uniqueness scoring. 2 500 free credits at https://serper.dev
SERPER_API_KEY=""

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by BullMQ for job queues and AI score caching (7-day TTL per content hash).
# Local dev: redis://localhost:6379
# Production: use Upstash Redis — https://console.upstash.com
REDIS_URL="redis://localhost:6379"

# ── Storage (Cloudflare R2 or AWS S3) ─────────────────────────────────────────
# Bucket where generated PDF audit reports are stored.
S3_BUCKET_NAME="sitenexis-reports"

# S3-compatible access key ID.
# For R2: found in Cloudflare dashboard → R2 → Manage R2 API tokens.
S3_ACCESS_KEY_ID="your-access-key-id"

# S3-compatible secret access key. Server-side only — never expose to client.
S3_SECRET_ACCESS_KEY="your-secret-access-key"

# Custom endpoint for Cloudflare R2 (zero egress fees):
#   https://[account-id].r2.cloudflarestorage.com
# For standard AWS S3, use:
#   https://s3.[region].amazonaws.com
S3_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe secret key — server-side only. Never expose to the browser.
# Use sk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret — used to verify Stripe event signatures.
# Generate via: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Or in Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe publishable key — safe for browser. Used in Checkout and Elements flows.
# Use pk_test_... for development, pk_live_... for production.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Resend (transactional email) ─────────────────────────────────────────────
# Used to send audit-complete notification emails.
# Get your API key at https://resend.com → API Keys.
# Leave empty to disable email notifications (safe for dev).
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="SiteNexis <noreply@sitenexis.com>"

# ── App ───────────────────────────────────────────────────────────────────────
# Canonical public URL of the app — used in links, redirects, and Stripe return URLs.
# Development: http://localhost:3000
# Production: https://sitenexis.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── v3 Config paths (optional) ───────────────────────────────────────────────
# Paths to the JSON config files in /config/. Relative to the project root.
# Omit these to use the default file locations below.
PROVIDER_WEIGHTS_CONFIG="config/provider-weights.json"
TRUST_DECAY_CONFIG="config/trust-decay-model.json"
SYNTHETIC_DETECTION_CONFIG="config/synthetic-detection-rules.json"
