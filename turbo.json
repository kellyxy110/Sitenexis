{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "PRISMA_QUERY_ENGINE_LIBRARY",
        "NODE_ENV",
        "VERCEL_ENV",
        "AGNES_API_KEY",
        "AGNES_BASE_URL",
        "AGNES_MODEL",
        "DATABASE_URL",
        "DIRECT_URL",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "GROQ_API_KEY",
        "OPENAI_API_KEY",
        "OPENROUTER_API_KEY",
        "OPENROUTER_HERMES_KEY",
        "OPENROUTER_DEEPSEEK_KEY",
        "OPENROUTER_GEMMA_KEY",
        "OPENROUTER_QWEN_KEY",
        "OPENROUTER_KIMI_KEY",
        "OPENROUTER_LLAMA_KEY",
        "BYNARA_API_KEY",
        "BYNARA_BASE_URL",
        "SERPER_API_KEY",
        "REDIS_URL",
        "S3_BUCKET_NAME",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_ENDPOINT",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_PRICE_STARTER",
        "STRIPE_PRICE_PRO",
        "STRIPE_PRICE_AGENCY",
        "STRIPE_PRICE_ENTERPRISE",
        "NEXT_PUBLIC_APP_URL",
        "PROVIDER_WEIGHTS_CONFIG",
        "TRUST_DECAY_CONFIG",
        "SYNTHETIC_DETECTION_CONFIG",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "CRAWL4AI_URL",
        "SCRAPY_SERVICE_URL",
        "SELF_AUDIT_SECRET",
        "VERCEL_DEPLOY_WEBHOOK_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:worker": {
      "cache": false,
      "persistent": true
    },
    "dev:watchdog": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:push": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
