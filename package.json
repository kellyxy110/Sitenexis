{
  "name": "sitenexis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "certify": "node scripts/launch-validation/run.mjs",
    "certify:coverage": "node scripts/launch-validation/coverage.mjs",
    "certify:golden": "node scripts/launch-validation/golden/run.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:push": "pnpm --filter @sitenexis/db db:push",
    "db:migrate": "pnpm --filter @sitenexis/db db:migrate",
    "db:seed": "pnpm --filter @sitenexis/db db:seed",
    "db:studio": "pnpm --filter @sitenexis/db db:studio"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "next": "15.3.9",
    "playwright": "^1.61.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
